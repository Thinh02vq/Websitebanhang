@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}
<section id="form">
	<!--form-->
	<div class="container">
		<div class="row">
			<div class="col-sm-12 col-sm-offset-1">
				<div class="login-form">
					<!--login form-->
					<h2> Đăng Nhập Tài Khoản Của Bạn</h2>
					<div asp-validation-summary="ModelOnly" class="text-danger"></div>
					<form asp-action="Login" asp-controller="Account">
						<div class="form-group">
							<label>Tên đăng nhập</label>
							<input asp-for="UserName" class="form-control" placeholder="Nhập tên đăng nhập" />
							<span asp-validation-for="UserName" class=" text-danger" />
						</div>
						<div class="form-group">
							<label>Mật Khẩu</label>
							<input asp-for="Password" class="form-control" placeholder="Nhập mật Khẩu" />
							<span asp-validation-for="Password" class=" text-danger" />
						</div>
						<button class="btn btn-default">Đăng Nhập</button>
						<a asp-action="Signup" asp-controller="Account">Tạo tài khoản mới</a>
					</form>
				</div><!--/login form-->
			</div>
		</div>
	</div>
</section><!--/form-->
@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}