@model UserModel
@{
	ViewData["Title"] = "Signup ";
}
<section id="form">
	<!--form-->
	<div class="container">
		<div class="row">
			<div class="col-sm-12 col-sm-offset-1">
				<div class="signup-form">
					<!--sign up form-->
					<h2>Đăng Ký Tài Khoản Mới!</h2>
					<div asp-validation-summary="ModelOnly" class="text-danger"></div>
					<form asp-action="Signup" asp-controller="Account">
						<div class="form-group">
							<label>Tên đăng nhập</label>
							<input asp-for="UserName" class="form-control" placeholder="Nhập tên đăng nhập" />
							<span asp-validation-for="UserName" class=" text-danger" />
						</div>
						<div class="form-group">
							<label>Địa chỉ Email</label>
							<input asp-for="Email" class="form-control" placeholder="Nhập địa chỉ Email" />
							<span asp-validation-for="Email" class=" text-danger" />
						</div>
						<div class="form-group">
							<label>Mật Khẩu</label>
							<input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu" />
							<span asp-validation-for="Password" class=" text-danger" />
						</div>
						<button type="submit" class="btn btn-default">Đăng Ký</button>
					</form>
				</div><!--/sign up form-->
			</div>
		</div>
	</div>
</section><!--/form-->
@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}