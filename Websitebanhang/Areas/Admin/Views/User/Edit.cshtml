@model AppUserModel

@{
    ViewData["Title"] = "Edit User";
}
<h3> Chỉnh Sửa User</h3>
<div class="col-md-6">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <div class="form-group">
            <label>Tên User</label>
            <input asp-for="UserName" required class="form-control" />
            <span asp-validation-for="UserName" class=" text-danger" />
        </div>
        <div class="form-group">
            <label>Email</label>
            <textarea asp-for="Email" required class="form-control"></textarea>
            <span asp-validation-for="Email" class=" text-danger" />
        </div>

        <div class="form-group">
            <label>Số điện thoại</label>
            <textarea asp-for="PhoneNumber" required class="form-control"></textarea>
            <span asp-validation-for="PhoneNumber" class=" text-danger" />
        </div>

        <div class="form-group">
            <label>Mật khẩu</label>
            <textarea asp-for="PasswordHash" readonly required class="form-control"></textarea>
            <span asp-validation-for="PasswordHash" class=" text-danger" />
        </div>
        <div class="form-group">
            <label>Roles</label>
            <select asp-for="RoleId" asp-items="ViewBag.Roles" class="form-control">
            </select>
            <span asp-validation-for="RoleId" class=" text-danger" />
        </div>
        <div class="form-group">
            <button class="btn btn-primary">Lưu </button>
        </div>
    </form>
    <a asp-action="Index" class="btn btn-danger">Trở lại trang User </a>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

