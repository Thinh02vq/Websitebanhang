@model IEnumerable<AppUserModel>
@{
    ViewData["Title"] = "List User";
}
<h1>Danh Sách User</h1>
<a class="btn btn-primary btn-sm" asp-action="Create" asp-controller="User">Thêm User</a>
<table class="table">
    <thead>
        <tr>
            <th scope="col">Tên User</th>
            <th scope="col">Email</th>
            <th scope="col">Mật Khẩu</th>
            <th scope="col">Số Điện Thoại</th>
            <th scope="col">Tuỳ chọn</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>@user.PasswordHash</td>
                <td>@user.PhoneNumber</td>
                <td>
                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-controller="User" asp-route-Id="@user.Id">Sửa</a>
                    <a class="btn btn-danger btn-sm confirmDeletion" asp-action="Delete" asp-controller="User" asp-route-Id="@user.Id">Xoá</a>
                </td>
            </tr>
        }
    </tbody>
</table>