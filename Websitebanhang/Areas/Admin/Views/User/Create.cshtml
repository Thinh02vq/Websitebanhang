@model AppUserModel

@{
    ViewData["Title"] = "Create User";
}
<h3> Thêm User</h3>
<div class="col-md-9">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-group">
            <label>Tên User</label>
            <input asp-for="UserName" required class="form-control" data-val-required="Tên đăng nhập không được để trống" />
            <span asp-validation-for="UserName" class=" text-danger" />
        </div>
        <div class="form-group">
            <label>Email</label>
            <textarea asp-for="Email" required class="form-control" data-val-required=" Email không được để trống"></textarea>
            <span asp-validation-for="Email" class=" text-danger" />
        </div>

        <div class="form-group">
            <label>Số điện thoại</label>
            <textarea asp-for="PhoneNumber" required class="form-control" data-val-required=" Số điện thoại không được để trống"></textarea>
            <span asp-validation-for="PhoneNumber" class=" text-danger" />
        </div>

        <div class="form-group">
            <label>Mật khẩu</label>
            <textarea asp-for="PasswordHash" required class="form-control"  ></textarea>
            <span asp-validation-for="PasswordHash" class=" text-danger" />
        </div>
        <div class="form-group">
            <label>Roles</label>
            <select asp-for="RoleId" asp-items="ViewBag.Roles" class="form-control" >
            </select>
            <span asp-validation-for="RoleId" class=" text-danger" />
        </div>
        <div class="form-group">
            <button class="btn btn-primary">Thêm User </button>
        </div>
    </form>
    <a asp-action="Index" class="btn btn-danger">Trở lại trang User </a>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            if ($.validator) {
                $.extend($.validator.messages, {
                    required: "Thông tin này không được để trống."
                });
            }
        });
    </script>
}

