@model IEnumerable<SliderModel>
@{
    ViewData["Title"] = "List Slider";
    Paginate pager = new Paginate();
    int pageNo = 0;
    if (ViewBag.Pager != null)
    {
        pager = ViewBag.Pager;
        pageNo = pager.CurrentPage;
    }
}
<h1>Danh Sách Slider</h1>
<a class="btn btn-primary btn-sm" asp-area="Admin" asp-action="Create" asp-controller="Slider">Thêm slider</a>
<table class="table" id="sliderTable">
    <thead>
        <tr>
            <th scope="col">STT</th>
            <th scope="col">Id</th>
            <th scope="col">Tên slider</th>
            <th scope="col">Mô tả</th>
            <th scope="col">Hình ảnh</th>
            <th scope="col">Trạng thái</th>
            <th scope="col">Tuỳ chọn</th>
        </tr>
    </thead>
    <tbody>
        @{
            int i = 1; // Khởi tạo biến đếm bằng 1 trước khi vào vòng lặp
        }
        @foreach (var item in Model)
        {
            <tr>
                <td>@i</td>
                <th scope="row">@item.Id</th>
                <td>@item.Name</td>
                <td>@Html.Raw(@item.Description)</td>
                <td><img src="~/media/sliders/@item.Image" width="100"></td>
                <td>
                    @if (item.Status == 1)
                    {
                        <span class="text text-success">Hiển thị</span>
                    }
                    else
                    {
                        <span class="text text-danger">Ẩn</span>
                    }
                </td>
                <td>
                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-controller="Slider" asp-route-Id="@item.Id">Sửa</a>
                    <a class="btn btn-danger btn-sm confirmDeletion" asp-action="Delete" asp-controller="Slider" asp-route-Id="@item.Id">Xoá</a>
                </td>
            </tr>
            i++; // Sau mỗi dòng, tăng i lên 1 để dòng sau là số kế tiếp
        }
    </tbody>
</table>
<partial name="_Paging" model="@pager" />
@section Scripts {
    <script>
        let table = new DataTable('#sliderTable');
    </script>
}