@model IEnumerable<OrderDetails>
@{
    ViewData["Title"] = "Details Order";
    decimal total = 0;
    decimal subtotal = 0;
}
<h1>Thông Tin Đơn Hàng</h1>
<table class="table">
    <thead>
        <tr>
            <th scope="col">Id</th>
            <th scope="col">Mã đơn hàng</th>
            <th scope="col">Khách hàng</th>
            <th scope="col">Tên sản phẩm</th>
            <th scope="col">Giá</th>
            <th scope="col">Số lượng</th>
            <th scope="col">Tổng</th> 
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            subtotal = item.Price * item.Quantity;
            total += subtotal;
            <tr>
                <input type="hidden" asp-for="@item.OrderCode" class="getId" />
                <td>@item.Id</td>
                <td>@item.OrderCode</td>
                <td>@item.UserName</td>
                <td>@item.Product?.Name</td>
                <td>@item.Price.ToString("#,##0") ₫</td>
                <td>@item.Quantity</td>
                <td>@subtotal.ToString("#,##0") ₫</td>
            </tr>
        }
        <tr>
            <td colspan="5" class="text-end"><strong>Tổng tiền:</strong></td>
            <td colspan="2"><strong>@total.ToString("#,##0") ₫</strong></td>
            <td>
                <select class="form-select form-select-sm" id="statusSelect">
                    <option value="1">Chờ xác nhận</option>
                    <option value="2">Đang giao hàng</option>
                    <option value="3">Đã giao hàng</option>
                    <option value="4">Đã huỷ</option>
                </select>
            </td>
        </tr>
    </tbody>
</table>
@section Scripts{
    <script>
        // Cập nhật trạng thái đơn hàng khi chọn một trạng thái mới
        $(document).ready(function () {
            $('#statusSelect').change(function () {
                var selectedStatus = $(this).val();
                var orderCode = $('.getId').val();
                $.ajax({// Gửi yêu cầu AJAX để cập nhật trạng thái đơn hàng
                    url: '@Url.Action("UpdateOrder", "Order", new { area = "Admin" })',
                    type: 'POST',
                    data: { orderCode: orderCode, status: selectedStatus },
                    success: function (response) {
                        Swal.fire("Thành công", response.message, "success").then((result) => {
                            // Sau khi người dùng nhấn OK trên thông báo, chuyển về trang Index
                            window.location.href = '@Url.Action("Index", "Order", new { area = "Admin" })';
                        });
                    },
                    error: function (xhr, status, error) {
                        Swal.fire("Lỗi", "Không thể cập nhật trạng thái", "error");
                    }
                });
            });
        });
    </script>
    
}