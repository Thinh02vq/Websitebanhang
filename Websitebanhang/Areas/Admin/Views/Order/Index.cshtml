@model IEnumerable<OrderModel>
@{
    ViewData["Title"] = "List Order";
    Paginate pager = new Paginate();
    int pageNo = 0;
    if (ViewBag.Pager != null)
    {
        pager = ViewBag.Pager;
        pageNo = pager.CurrentPage;
    }
}
<h1>Danh Sách Đơn Hàng</h1>
<table class="table" id="orderTable">
    <thead>
        <tr>
            <th scope="col">Mã đơn hàng</th>
            <th scope="col">Khách hàng</th>
            <th scope="col">Ngày tạo</th>
            <th scope="col">Trạng thái</th>
            <th scope="col">Tuỳ chọn</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <th scope="row">@item.OrderCode</th>
                <td>@item.UserName</td>
                <td>@item.CreatedDate</td>
                <td>
                    @if (item.status == 1)
                    {
                        <span class="text text-success">Đang xử lý</span>
                    }
                    else if (item.status == 2)
                    {
                        <span class="text text-primary">Đang giao hàng</span>
                    }
                    else if (item.status == 3)
                    {
                        <span class="text text-success">Đã giao hàng</span>
                    }
                    else
                    {
                        <span class="text text-danger">Đã huỷ</span>
                    }
                </td>
                <td>
                    <a class="btn btn-warning btn-sm" asp-action="ViewOrder" asp-controller="Order" asp-route-ordercode="@item.OrderCode">Xem</a>
                    <a class="btn btn-danger btn-sm confirmDeletion" asp-action="Delete" asp-controller="Order" asp-route-Id="@item.Id">Xoá</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<partial name="_Paging" model="@pager" />
@section Scripts {
    <script>
        let table = new DataTable('#orderTable');
    </script>
}